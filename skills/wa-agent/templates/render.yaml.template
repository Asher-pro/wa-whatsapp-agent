services:
  - type: web
    name: {{AGENT_NAME}}-whatsapp
    runtime: python
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn main:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: GREEN_API_URL
        value: {{GREEN_API_URL}}
      - key: GREEN_API_INSTANCE
        value: {{GREEN_API_INSTANCE}}
      - key: GREEN_API_TOKEN
        value: {{GREEN_API_TOKEN}}
      - key: {{LLM_API_KEY_NAME}}
        value: {{LLM_API_KEY_VALUE}}
      - key: LLM_MODEL
        value: {{LLM_MODEL}}
      - key: SYSTEM_PROMPT
        value: {{SYSTEM_PROMPT}}
      - key: MAX_HISTORY
        value: "{{MAX_HISTORY}}"
      - key: DATABASE_PATH
        value: /data/conversations.db
    disk:
      name: data
      mountPath: /data
      sizeGB: 1
